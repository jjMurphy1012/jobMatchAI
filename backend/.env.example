# App Configuration
APP_NAME=Job Matching AI
DEBUG=false
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobmatch

# Auth
JWT_SECRET_KEY=change-me-before-production
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_SAMESITE=lax
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# ADMIN_EMAILS=admin@example.com

# Storage
STORAGE_BACKEND=local
# LOCAL_STORAGE_DIR=uploads
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_RESUME_BUCKET=resumes
# SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# LinkedIn Credentials
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

# Email Service (optional - for later)
# SENDGRID_API_KEY=SG.your-sendgrid-key

# Matching Configuration (optional - defaults shown)
# MATCH_THRESHOLD=70
# MIN_THRESHOLD=30
# THRESHOLD_STEP=5
# TARGET_JOBS=10

# Data Retention (optional)
# DATA_RETENTION_DAYS=7

# Scheduler (optional - defaults shown)
# PUSH_HOUR=7
# PUSH_MINUTE=0
# TIMEZONE=America/New_York
